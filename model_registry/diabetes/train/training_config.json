{
    "dataset_name": "diabetes",
    "target_column": "Outcome",
    "random_state": 42,
    "test_size": 0.15,
    "valid_size": 0.15,
    "cv_folds": 5,
    "feature_engineering": {
        "enabled": true,
        "engineered_features": [
            "Glucose_BMI",
            "Glucose_Age",
            "BMI_Age",
            "Insulin_Glucose_Ratio",
            "DPF_Age_Interaction",
            "Metabolic_Load"
        ]
    },
    "feature_selection": {
        "method": "SelectKBest(f_classif)",
        "min_features_to_keep": 8,
        "max_features_to_keep": 14,
        "actual_selected_feature_count": 14
    },
    "preprocessing": {
        "imputer": "median",
        "scaler": "standard_scaler",
        "log_transform_for_high_skew_features": true,
        "high_skew_feature_threshold_abs_skew": 1.0,
        "skewed_columns_detected": [
            "Insulin",
            "DiabetesPedigreeFunction",
            "Age",
            "Glucose_Age",
            "Insulin_Glucose_Ratio",
            "DPF_Age_Interaction",
            "Metabolic_Load",
            "High_Glucose",
            "Very_High_Glucose",
            "High_Risk_Age",
            "Glucose_Insulin_Product"
        ]
    },
    "candidate_models": {
        "LogisticRegression": true,
        "RandomForest": true,
        "ExtraTrees": true,
        "HistGradientBoosting": true,
        "XGBoost": true,
        "CatBoost": true
    },
    "final_model_selection": {
        "best_model_name": "ExtraTrees",
        "selection_strategy": "highest composite full-pipeline CV score",
        "composite_score_formula": "0.30*roc_auc + 0.20*pr_auc + 0.20*recall + 0.15*f1 + 0.10*balanced_accuracy + 0.05*precision"
    },
    "calibration": {
        "enabled": true,
        "method": "sigmoid",
        "cv": 5
    },
    "input_feature_count": 8,
    "engineered_feature_count": 20,
    "selected_feature_count": 14
}