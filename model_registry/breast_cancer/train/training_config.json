{
    "dataset_name": "breast_cancer",
    "target_column": "target",
    "random_state": 42,
    "test_size": 0.15,
    "valid_size": 0.15,
    "cv_folds": 5,
    "feature_selection": {
        "method": "SelectKBest(f_classif)",
        "min_features_to_keep": 10,
        "max_features_to_keep": 20,
        "actual_selected_feature_count": 20
    },
    "preprocessing": {
        "imputer": "median",
        "scaler": "standard_scaler",
        "log_transform_for_high_skew_features": true,
        "high_skew_feature_threshold_abs_skew": 1.0,
        "skewed_columns_detected": [
            "area_mean",
            "compactness_mean",
            "concavity_mean",
            "concave_points_mean",
            "fractal_dimension_mean",
            "radius_se",
            "texture_se",
            "perimeter_se",
            "area_se",
            "smoothness_se",
            "compactness_se",
            "concavity_se",
            "concave_points_se",
            "symmetry_se",
            "fractal_dimension_se",
            "radius_worst",
            "perimeter_worst",
            "area_worst",
            "compactness_worst",
            "concavity_worst",
            "symmetry_worst",
            "fractal_dimension_worst",
            "radius_worst_to_mean",
            "area_worst_to_mean",
            "compactness_concavity_interaction"
        ]
    },
    "candidate_models": {
        "LogisticRegression": true,
        "RandomForest": true,
        "ExtraTrees": true,
        "XGBoost": true,
        "CatBoost": true
    },
    "final_model_selection": {
        "best_model_name": "ExtraTrees",
        "selection_strategy": "highest composite full-pipeline CV score",
        "composite_score_formula": "0.35*roc_auc + 0.20*pr_auc + 0.20*f1 + 0.15*recall + 0.10*balanced_accuracy"
    },
    "calibration": {
        "enabled": true,
        "method": "sigmoid",
        "cv": 5
    },
    "input_feature_count": 30,
    "engineered_feature_count": 35,
    "selected_feature_count": 20
}